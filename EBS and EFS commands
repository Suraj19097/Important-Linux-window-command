3. verify partition is created or not 
   [root@ip-172-31-79-146 ec2-user]# lsblk

4. format the filesystem
   [root@ip-172-31-79-146 ec2-user]# sudo mkfs.ext4 /dev/nvme0n1p4

5. create dir to mount filesystem
    sudo mkdir /data

6. mount filesystem on path
    sudo mount /dev/nvme0n1p4 /data

7. verify filesystem is mounted or  not
   [root@ip-172-31-79-146 ec2-user]# df -Th

8. Right now /data may NOT persist after reboot unless added to fstab.
  Make Mount Permanent-:
  Step 1: Get UUID
    sudo blkid /dev/nvme0n1p4
    
    [root@ip-172-31-79-146 ec2-user]# sudo blkid /dev/nvme0n1p4
    /dev/nvme0n1p4: UUID="aff0e4ec-57c2-4da0-807c-f4dc3fe494bd" BLOCK_SIZE="4096" TYPE="ext4" PARTUUID="6791faec-6bcd-4c13-99dc-44b4435fa451"

here UUID="aff0e4ec-57c2-4da0-807c-f4dc3fe494bd" is UUID

   Step 2: Add to /etc/fstab
      sudo vi /etc/fstab
      [root@ip-172-31-79-146 ec2-user]# cat /etc/fstab
      UUID=5a97cc7b-538e-4a0f-8afc-48da2388aeaa       /       xfs     defaults        0       0
      UUID=663D-A7B7  /boot/efi       vfat    defaults,uid=0,gid=0,umask=077,shortname=winnt  0       2
      UUID=aff0e4ec-57c2-4da0-807c-f4dc3fe494bd   /data   ext4   defaults,nofail   0   0

to test -:
    sudo mount -a


